# Etherscan API V2 key.
# One key serves Ethereum, Arbitrum, Base, and optionally BSC via the chainid param.
ETHERSCAN_API_KEY=""
# Optional Pro Plus Etherscan endpoint for public nametags.
# Set to "true" only when the key can access module=nametag&action=getaddresstag.
ETHERSCAN_NAMETAG_ENABLED="false"

# Optional live address/entity labels. Chainbase has a free plan and supports BSC chain_id=56.
CHAINBASE_API_KEY=""
CHAINBASE_LABELS_ENABLED="true"

# Optional: preferred live provider for supported EVM chains. Auto provider
# tries NodeReal first, then falls back to Etherscan V2 where available.
NODEREAL_API_KEY=""

# Backward-compatible BSC key; used if NODEREAL_API_KEY is empty.
NODEREAL_BSC_API_KEY=""

# Solscan Pro API V2 key for Solana analysis.
SOLSCAN_API_KEY=""

# Optional: max live wallet-address fetches running at the same time.
# Defaults to 2 and is capped at 8 to reduce provider rate-limit pressure.
ANALYZE_LIVE_ADDRESS_CONCURRENCY="2"

# Optional: timeout for each live provider HTTP request.
# Defaults to 30000 ms and is capped at 120000 ms.
ANALYZE_LIVE_PROVIDER_TIMEOUT_MS="30000"

# Optional: comma- or whitespace-separated default wallets to prefill the
# workbench textarea. Useful for local-only test wallets you do not want
# to commit. Leave empty in shared examples.
WALLET_MAP_DEFAULT_ADDRESSES=""

# Secret used to sign wallet-login and anonymous-session cookies.
# Set a long random value in local .env.local or the deployment provider.
WALLET_MAP_SESSION_SECRET=""

# Optional: limit how many analyses an unsigned browser session can create.
# Use 0, unlimited, or leave empty to disable the limit.
WALLET_MAP_ANON_ANALYSIS_LIMIT="5"

# Optional: WalletConnect Cloud project ID used by RainbowKit mobile/QR wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Optional storage and label management. Leave disabled for local fixture
# mode. For Vercel preview and production deployments, enable Redis after
# adding a managed Redis URL such as an Upstash rediss:// connection string.
STORAGE_POSTGRES_ENABLED="false"
DATABASE_URL=""
STORAGE_REDIS_ENABLED="false"
REDIS_URL=""
LABEL_DATABASE_ENABLED="false"
LABEL_REDIS_CACHE_ENABLED="false"
LABEL_LIST_CACHE_ENABLED="false"
NEXT_PUBLIC_LABEL_MANAGER_ENABLED="false"
