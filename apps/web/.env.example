# Etherscan API V2 key.
# One key serves Ethereum, Arbitrum, Base, and optionally BSC via the chainid param.
ETHERSCAN_API_KEY=""

# Optional: preferred live provider for supported EVM chains. Auto provider
# tries NodeReal first, then falls back to Etherscan V2 where available.
NODEREAL_API_KEY=""

# Backward-compatible BSC key; used if NODEREAL_API_KEY is empty.
NODEREAL_BSC_API_KEY=""

# Solscan Pro API V2 key for Solana analysis.
SOLSCAN_API_KEY=""

# Optional: comma- or whitespace-separated default wallets to prefill the
# workbench textarea. Useful for local-only test wallets you do not want
# to commit. Leave empty in shared examples.
WALLET_MAP_DEFAULT_ADDRESSES=""
