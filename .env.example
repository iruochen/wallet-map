# Copy this file to .env.local for local development.
# Never commit real API keys, RPC URLs with credentials, private notes, or wallet data.

# App
NEXT_PUBLIC_APP_NAME="Wallet Map"

# Chain data providers
ETHEREUM_RPC_URL=""
ARBITRUM_RPC_URL=""
BASE_RPC_URL=""
BSC_RPC_URL=""

# Etherscan API V2
# One key can query supported EVM chains by passing chainid.
ETHERSCAN_API_KEY=""
# Optional Pro Plus Etherscan endpoint for public nametags.
# Set to "true" only when the key can access module=nametag&action=getaddresstag.
ETHERSCAN_NAMETAG_ENABLED="false"
CHAINBASE_API_KEY=""
CHAINBASE_LABELS_ENABLED="true"
NODEREAL_API_KEY=""
NODEREAL_BSC_API_KEY=""
SOLSCAN_API_KEY=""
ANALYZE_LIVE_ADDRESS_CONCURRENCY="2"
ANALYZE_LIVE_PROVIDER_TIMEOUT_MS="30000"

# Cookie signing for wallet login and anonymous history sessions.
WALLET_MAP_SESSION_SECRET=""

# WalletConnect Cloud project ID for RainbowKit mobile/QR wallets.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Optional local storage. Leave empty for fixture mode or Vercel deployments
# without managed PostgreSQL/Redis. Set the *_ENABLED flags to "true" only
# after the matching service URL is configured.
STORAGE_POSTGRES_ENABLED="false"
DATABASE_URL=""
STORAGE_REDIS_ENABLED="false"
REDIS_URL=""
LABEL_DATABASE_ENABLED="false"
LABEL_REDIS_CACHE_ENABLED="false"
LABEL_LIST_CACHE_ENABLED="false"
NEXT_PUBLIC_LABEL_MANAGER_ENABLED="false"
