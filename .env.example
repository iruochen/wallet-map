# Copy this file to .env.local for local development.
# Never commit real API keys, RPC URLs with credentials, private notes, or wallet data.

# App
NEXT_PUBLIC_APP_NAME="Wallet Map"

# Chain data providers
ETHEREUM_RPC_URL=""
ARBITRUM_RPC_URL=""
BASE_RPC_URL=""
BSC_RPC_URL=""

# Etherscan-like APIs
ETHERSCAN_API_KEY=""
ARBISCAN_API_KEY=""
BASESCAN_API_KEY=""
BSCSCAN_API_KEY=""

# Local storage
DATABASE_URL="postgresql://wallet_map:wallet_map@localhost:5432/wallet_map"
REDIS_URL="redis://localhost:6379"
